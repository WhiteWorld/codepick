---
import BaseLayout from '../layouts/BaseLayout.astro';
import FilterBar from '../components/FilterBar.astro';
import PlanCard from '../components/PlanCard.astro';
import QuickPicker from '../components/QuickPicker.astro';
import { getAllPlansLocalized, overallScore } from '../lib/data';
import { t, localePath, type Locale } from '../lib/i18n';

interface Props { lang: Locale }
const { lang } = Astro.props;

// Load raw API data (YAML not normalized, access raw fields)
import { getApi } from '../lib/data';
const arkRaw = getApi('ark-coding-plan') as any;
const bailianRaw = getApi('bailian-coding-plan') as any;

const plans = getAllPlansLocalized(lang).sort((a, b) => overallScore(b.scores) - overallScore(a.scores));
const filterTags = ['all', 'ide', 'diy', 'cli', 'budget', 'china', 'agent'];

const seoTitle = t('codingPlan.metaTitle', lang);
const seoDesc = t('codingPlan.metaDesc', lang);

const apiCards = [
  {
    raw: arkRaw,
    accentColor: '#f97316',
    badge: lang === 'zh' ? '🔥 官网活动价' : '🔥 Official promo',
  },
  {
    raw: bailianRaw,
    accentColor: '#8b5cf6',
    badge: lang === 'zh' ? '💜 Lite 停止新购' : '💜 Lite no longer sold',
  },
];

const whyCards = [
  {
    icon: '💰',
    title: t('codingPlan.why1Title', lang),
    desc: t('codingPlan.why1Desc', lang),
  },
  {
    icon: '🔀',
    title: t('codingPlan.why2Title', lang),
    desc: t('codingPlan.why2Desc', lang),
  },
  {
    icon: '🇨🇳',
    title: t('codingPlan.why3Title', lang),
    desc: t('codingPlan.why3Desc', lang),
  },
];

const howSteps = [
  {
    num: '01',
    title: t('codingPlan.step1', lang),
    desc: t('codingPlan.step1Desc', lang),
    icon: '🖥️',
  },
  {
    num: '02',
    title: t('codingPlan.step2', lang),
    desc: t('codingPlan.step2Desc', lang),
    icon: '🔑',
  },
  {
    num: '03',
    title: t('codingPlan.step3', lang),
    desc: t('codingPlan.step3Desc', lang),
    icon: '🚀',
  },
];
---

<BaseLayout title={seoTitle} description={seoDesc} lang={lang}>
  <!-- Hero -->
  <section class="relative container pt-20 pb-16 text-center overflow-hidden">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true" style="background-image: radial-gradient(var(--surface-border) 1px, transparent 1px); background-size: 24px 24px; opacity: 0.35;"></div>

    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold mb-6 border" style="background: #f97316 18; color: #f97316; border-color: #f97316 40;">
      {lang === 'zh' ? '🔥 AI 编程新范式' : '🔥 New AI Coding Paradigm'}
    </div>

    <h1 class="text-4xl md:text-5xl font-bold text-[var(--text-primary)] mb-5 leading-tight tracking-tight">
      {t('codingPlan.heroTitle', lang)}
    </h1>
    <p class="text-base md:text-lg text-[var(--text-secondary)] max-w-2xl mx-auto mb-8 leading-relaxed">
      {t('codingPlan.heroSubtitle', lang)}
    </p>

    <div class="flex justify-center gap-4 flex-wrap">
      <a href="#api-plans" class="btn btn-primary px-6 py-2.5 text-base">
        {lang === 'zh' ? '查看推荐方案' : 'View Recommended Plans'}
      </a>
      <a href="#all-plans" class="btn btn-ghost px-6 py-2.5">
        {lang === 'zh' ? '浏览全部方案' : 'Browse All Plans'}
      </a>
    </div>
  </section>

  <!-- Why It Matters -->
  <section class="container mb-16 reveal">
    <h2 class="text-2xl font-bold text-[var(--text-primary)] mb-2 text-center">{t('codingPlan.whyTitle', lang)}</h2>
    <p class="text-sm text-[var(--text-muted)] text-center mb-8">
      {lang === 'zh'
        ? '选对方案，能力、成本、体验全面提升'
        : 'The right plan elevates your coding ability, cost efficiency, and experience'}
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {whyCards.map(card => (
        <div class="card p-6 text-center">
          <div class="text-4xl mb-4">{card.icon}</div>
          <h3 class="text-base font-bold text-[var(--text-primary)] mb-2 m-0">{card.title}</h3>
          <p class="text-sm text-[var(--text-secondary)] m-0 leading-relaxed">{card.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- How It Works -->
  <hr class="section-divider my-16" />
  <section class="container mb-16 reveal">
    <h2 class="text-2xl font-bold text-[var(--text-primary)] mb-2 text-center">{t('codingPlan.howTitle', lang)}</h2>
    <p class="text-sm text-[var(--text-muted)] text-center mb-8">
      {lang === 'zh' ? '三步组合，快速上手 AI 辅助编程' : 'Three steps to start AI-assisted coding'}
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative">
      <!-- Connecting line (desktop) -->
      <div class="hidden md:block absolute top-8 left-1/3 right-1/3 h-0.5 bg-gradient-to-r from-[var(--brand-500)] to-[var(--brand-500)] opacity-30" style="top: 2rem;"></div>
      {howSteps.map((step, i) => (
        <div class="card p-6 relative">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold shrink-0"
                 style="background: var(--brand-500); color: white;">
              {step.num}
            </div>
            <div class="text-2xl">{step.icon}</div>
          </div>
          <h3 class="text-base font-bold text-[var(--text-primary)] mb-2 m-0">{step.title}</h3>
          <p class="text-sm text-[var(--text-secondary)] m-0 leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured API Coding Plans -->
  <hr class="section-divider my-16" />
  <section class="container mb-16 reveal" id="api-plans">
    <h2 class="text-2xl font-bold text-[var(--text-primary)] mb-2 text-center">{t('codingPlan.apiPlansTitle', lang)}</h2>
    <p class="text-sm text-[var(--text-muted)] text-center mb-8">{t('codingPlan.apiPlansDesc', lang)}</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {apiCards.map(({ raw, accentColor, badge }) => raw && (
        <div class="card p-6 border-2 transition-all hover:shadow-lg" style={`border-color: ${accentColor}40;`}>
          <!-- Header -->
          <div class="flex items-start justify-between mb-4">
            <div class="flex items-center gap-3">
              {raw.logo && (
                <img src={raw.logo} alt={raw.name} class="w-10 h-10 rounded-lg object-contain" loading="lazy" />
              )}
              <div>
                <h3 class="text-base font-bold text-[var(--text-primary)] m-0">{raw.name}</h3>
                <span class="text-xs font-semibold px-2 py-0.5 rounded-full" style={`background: ${accentColor}20; color: ${accentColor};`}>
                  {badge}
                </span>
              </div>
            </div>
          </div>

          <!-- Pricing Tiers -->
          {raw.pricing?.plans && (
            <div class={`grid gap-3 mb-4 ${raw.pricing.plans.length > 1 ? 'grid-cols-2' : 'grid-cols-1'}`}>
              {raw.pricing.plans.map((plan: any) => (
                <div class="rounded-lg p-3 border border-[var(--surface-border)]" style={`background: ${accentColor}08;`}>
                  <div class="text-xs text-[var(--text-muted)] mb-1">{plan.name}</div>
                  <div class="text-xl font-bold" style={`color: ${accentColor};`}>
                    ¥{plan.price}<span class="text-xs font-normal text-[var(--text-muted)]">/月</span>
                  </div>
                  {plan.original_price && (
                    <div class="text-xs text-[var(--text-muted)] line-through">¥{plan.original_price}/月</div>
                  )}
                  {plan.limits && (
                    <div class="text-xs text-[var(--text-secondary)] mt-1">{plan.limits}</div>
                  )}
                </div>
              ))}
            </div>
          )}

          <!-- Models -->
          {raw.features?.supported_models && (
            <div class="mb-4">
              <div class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wide mb-2">
                {t('codingPlan.models', lang)}
              </div>
              <div class="flex flex-wrap gap-1.5">
                {raw.features.supported_models.slice(0, 5).map((m: string) => (
                  <span class="tag text-xs">{m}</span>
                ))}
                {raw.features.supported_models.length > 5 && (
                  <span class="tag text-xs text-[var(--text-muted)]">+{raw.features.supported_models.length - 5}</span>
                )}
              </div>
            </div>
          )}

          <!-- Supported Clients -->
          {raw.features?.supported_clients && (
            <div class="mb-5">
              <div class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wide mb-2">
                {t('codingPlan.supportedClients', lang)}
              </div>
              <div class="text-xs text-[var(--text-secondary)]">
                {raw.features.supported_clients.join(' · ')}
              </div>
            </div>
          )}

          <!-- CTA -->
          <a
            href={raw.affiliate_url || raw.url}
            target="_blank"
            rel="noopener noreferrer"
            class="btn w-full text-center py-2 text-sm font-semibold rounded-lg transition-colors"
            style={`background: ${accentColor}; color: white; border: none;`}
          >
            {t('codingPlan.subscribe', lang)} →
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Quick Picker -->
  <hr class="section-divider my-16" />
  <section class="container mb-16 reveal"><QuickPicker lang={lang} /></section>

  <!-- All Plans Grid -->
  <hr class="section-divider my-16" />
  <section class="container mb-20 reveal" id="all-plans">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-xl font-bold text-[var(--text-primary)] m-0">{t('codingPlan.allPlansTitle', lang)}</h2>
        <p class="text-xs text-[var(--text-muted)] mt-1 mb-0">
          {lang === 'zh' ? `共 ${plans.length} 个方案，按综合评分排序` : `${plans.length} plans, sorted by overall score`}
        </p>
      </div>
    </div>
    <div class="mb-6"><FilterBar tags={filterTags} activeTag="all" lang={lang} /></div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {plans.map(plan => (
        <div data-plan-tags={plan.tags.join(',')} data-plan-id={plan.id}>
          <PlanCard plan={plan} lang={lang} />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
