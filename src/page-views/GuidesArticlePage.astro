---
import BaseLayout from '../layouts/BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ShareBar from '../components/ShareBar.astro';
import { t, localePath, getCollectionName, type Locale } from '../lib/i18n';
import { getAllToolsLocalized, overallScore } from '../lib/data';
import { getCollection } from 'astro:content';

interface Props { guide: any; lang: Locale }
const { guide, lang } = Astro.props;
const { Content, headings } = await guide.render();

// 相关指南：共享 tag 最多的指南，排除自身，最多 3 篇
const guidesCollection = getCollectionName('guides', lang) as 'guides' | 'guides-en';
const allGuides = await getCollection(guidesCollection);
const currentTags: string[] = (guide.data.tags || []).map((t: string) => t.toLowerCase());
const relatedGuides = allGuides
  .filter(g => g.slug !== guide.slug && !g.data.draft)
  .map(g => ({
    guide: g,
    shared: (g.data.tags || []).filter((t: string) => currentTags.includes(t.toLowerCase())).length,
  }))
  .filter(x => x.shared > 0)
  .sort((a, b) => b.shared - a.shared)
  .slice(0, 3)
  .map(x => x.guide);

// 相关对比文章：跨类型推荐，共享 tag 最多，最多 2 篇
const compareCollection = getCollectionName('compare', lang) as 'compare' | 'compare-en';
const allArticles = await getCollection(compareCollection);
const relatedArticles = allArticles
  .filter(a => !a.data.draft)
  .map(a => ({
    article: a,
    shared: (a.data.tags || []).filter((tag: string) => currentTags.includes(tag.toLowerCase())).length,
  }))
  .filter(x => x.shared > 0)
  .sort((a, b) => b.shared - a.shared)
  .slice(0, 3)
  .map(x => x.article);

// 文章中提到的工具：tags 中与实际工具 ID 匹配，最多 4 个
const allTools = getAllToolsLocalized(lang);
const toolIds = new Set(allTools.map((tool: any) => tool.id));
const mentionedTools = allTools
  .filter((tool: any) => currentTags.includes(tool.id.toLowerCase()))
  .slice(0, 4);

function tagHref(tag: string) {
  return toolIds.has(tag) ? localePath(`/tool/${tag}`, lang) : localePath('/guides', lang);
}

const siteUrl = 'https://codepick.dev';
const guidePath = localePath(`/guides/${guide.slug}`, lang);
const guideUrl = `${siteUrl}${guidePath}`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t('bread.home', lang), item: siteUrl },
    { '@type': 'ListItem', position: 2, name: t('bread.guides', lang), item: `${siteUrl}${localePath('/guides', lang)}` },
    { '@type': 'ListItem', position: 3, name: guide.data.title, item: guideUrl },
  ],
};

// Build HowTo steps from h2/h3 headings (skip intro-like headings)
const howToSteps = headings
  .filter((h: any) => h.depth <= 3)
  .slice(0, 8)
  .map((h: any, i: number) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: h.text,
    url: `${guideUrl}#${h.slug}`,
  }));

const baseArticleSchema = {
  '@context': 'https://schema.org',
  name: guide.data.title,
  description: guide.data.description,
  datePublished: guide.data.date,
  dateModified: guide.data.updated_at || guide.data.date,
  url: guideUrl,
  image: `${siteUrl}/og-image.png`,
  inLanguage: lang === 'zh' ? 'zh-CN' : 'en',
  author: { '@type': 'Organization', name: 'CodePick', url: siteUrl },
};

const canUseHowTo = guide.data.article_type === 'howto' && howToSteps.length > 0;

const articleSchema = canUseHowTo
  ? {
      ...baseArticleSchema,
      '@type': 'HowTo',
      step: howToSteps,
    }
  : {
      ...baseArticleSchema,
      '@type': guide.data.article_type === 'explainer' ? 'TechArticle' : 'Article',
    };
---

<BaseLayout
  title={`${guide.data.title} | CodePick`}
  description={guide.data.description}
  jsonLd={[articleSchema, breadcrumbSchema]}
  lang={lang}
>
  <article class="container py-12 max-w-3xl">
    <nav class="text-xs text-[var(--text-muted)] mb-6">
      <a href={localePath('/', lang)} class="hover:text-[var(--text-primary)] no-underline">{t('bread.home', lang)}</a>
      <span class="mx-1">/</span>
      <a href={localePath('/guides', lang)} class="hover:text-[var(--text-primary)] no-underline">{t('bread.guides', lang)}</a>
      <span class="mx-1">/</span>
      <span class="text-[var(--text-secondary)]">{guide.data.title}</span>
    </nav>

    <header class="mb-8">
      <div class="flex flex-wrap gap-2 mb-3">
        {guide.data.tags?.map((tag: string) => (
          <a href={tagHref(tag)} class="tag no-underline hover:border-[var(--brand-400)] hover:text-[var(--brand-400)] transition-colors">{tag}</a>
        ))}
      </div>
      <h1 class="text-2xl md:text-3xl font-bold text-[var(--text-primary)] mb-3 mt-0">{guide.data.title}</h1>
      <p class="text-[var(--text-secondary)] text-base mb-3">{guide.data.description}</p>
      <div class="text-xs text-[var(--text-muted)]">
        {t('guides.pubDate', lang)} {guide.data.date}
      </div>
    </header>

    <TableOfContents headings={headings} lang={lang} />

    <div class="prose prose-sm max-w-none
      prose-headings:text-[var(--text-primary)] prose-headings:font-semibold
      prose-h2:text-xl prose-h2:mt-8 prose-h2:mb-4 prose-h2:border-b prose-h2:border-[var(--surface-border)] prose-h2:pb-2
      prose-h3:text-base prose-h3:mt-6 prose-h3:mb-3
      prose-p:text-[var(--text-secondary)] prose-p:leading-relaxed
      prose-a:text-[var(--brand-400)] prose-a:no-underline hover:prose-a:underline
      prose-strong:text-[var(--text-primary)]
      prose-code:text-[var(--brand-400)] prose-code:bg-[var(--surface-hover)] prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:text-xs
      prose-pre:bg-[var(--surface-card)] prose-pre:border prose-pre:border-[var(--surface-border)] prose-pre:text-[var(--text-primary)]
      prose-table:text-sm
      prose-th:text-[var(--text-secondary)] prose-th:font-medium prose-th:bg-[var(--surface-card)]
      prose-td:text-[var(--text-secondary)] prose-td:border-[var(--surface-border)]
      prose-tr:border-[var(--surface-border)]
      prose-blockquote:border-l-[var(--brand-400)] prose-blockquote:text-[var(--text-muted)]
      prose-li:text-[var(--text-secondary)]
      prose-hr:border-[var(--surface-border)]
      prose-ol:list-decimal prose-ul:list-disc
    ">
      <Content />
    </div>

    <ShareBar url={guideUrl} title={guide.data.title} description={guide.data.description} lang={lang} />

    <!-- Mentioned Tools -->
    {mentionedTools.length > 0 && (
      <section class="mt-12 pt-6 border-t border-[var(--surface-border)]">
        <h2 class="text-lg font-semibold text-[var(--text-primary)] mb-4 mt-0">{t('section.mentionedTools', lang)}</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
          {mentionedTools.map((tool: any) => (
            <a href={localePath(`/tool/${tool.id}`, lang)} class="card p-4 block no-underline group hover:border-[var(--brand-500)] transition-colors text-center">
              <div class="w-10 h-10 rounded-lg bg-[var(--surface-hover)] flex items-center justify-center text-base font-bold text-[var(--brand-400)] mx-auto mb-2">
                {tool.name.charAt(0)}
              </div>
              <div class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--brand-400)] transition-colors">{tool.name}</div>
              <div class="text-xs text-[var(--text-muted)] mt-1">{t('score.overall', lang)} {overallScore(tool.scores).toFixed(1)}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- CTA: 选型入口 -->
    <section class="mt-12 p-6 rounded-xl border border-[var(--brand-500)] bg-gradient-to-br from-[var(--surface-card)] to-[rgba(49,46,129,0.15)] text-center">
      <h2 class="text-lg font-bold text-[var(--text-primary)] mb-2 mt-0">{t('article.ctaGuideTitle', lang)}</h2>
      <p class="text-sm text-[var(--text-secondary)] mb-4">{t('article.ctaGuideDesc', lang)}</p>
      <a href={localePath('/tools/overview', lang)} class="btn btn-primary">{t('article.ctaBtn', lang)}</a>
    </section>

    <!-- Related Guides -->
    {relatedGuides.length > 0 && (
      <section class="mt-10 pt-6 border-t border-[var(--surface-border)]">
        <h2 class="text-lg font-semibold text-[var(--text-primary)] mb-4 mt-0">{t('section.relatedGuides', lang)}</h2>
        <div class="grid grid-cols-1 gap-3">
          {relatedGuides.map(g => (
            <a href={localePath(`/guides/${g.slug}`, lang)} class="card p-4 block no-underline group hover:border-[var(--brand-500)] transition-colors">
              <h3 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--brand-400)] m-0 mb-1">{g.data.title}</h3>
              <p class="text-xs text-[var(--text-muted)] m-0 line-clamp-1">{g.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Related Compare Articles (cross-type) -->
    {relatedArticles.length > 0 && (
      <section class="mt-8 pt-6 border-t border-[var(--surface-border)]">
        <h2 class="text-lg font-semibold text-[var(--text-primary)] mb-4 mt-0">{t('section.relatedCompare', lang)}</h2>
        <div class="grid grid-cols-1 gap-3">
          {relatedArticles.map(a => (
            <a href={localePath(`/compare/${a.slug}`, lang)} class="card p-4 block no-underline group hover:border-[var(--brand-500)] transition-colors">
              <h3 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--brand-400)] m-0 mb-1">{a.data.title}</h3>
              <p class="text-xs text-[var(--text-muted)] m-0 line-clamp-1">{a.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="mt-6">
      <a href={localePath('/guides', lang)} class="text-sm text-[var(--brand-400)] no-underline hover:underline">{t('link.backGuides', lang)}</a>
    </div>
  </article>
</BaseLayout>
