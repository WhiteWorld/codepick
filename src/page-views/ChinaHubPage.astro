---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlanCard from '../components/PlanCard.astro';
import ToolCard from '../components/ToolCard.astro';
import { getAllToolsLocalized, getAllPlansLocalized, overallScore } from '../lib/data';
import { t, localePath, getCollectionName, type Locale } from '../lib/i18n';
import { getCollection } from 'astro:content';

interface Props { lang: Locale }
const { lang } = Astro.props;

const allTools = getAllToolsLocalized(lang);
const chinaTools = allTools
  .filter(t => (t as any).scores?.china_friendly >= 7)
  .sort((a, b) => (b.scores.china_friendly ?? 0) - (a.scores.china_friendly ?? 0));

const allPlans = getAllPlansLocalized(lang);
const chinaPlans = allPlans
  .filter(p => p.scores.china_friendly >= 7)
  .sort((a, b) => overallScore(b.scores) - overallScore(a.scores));

// 国内相关文章
const compareCollection = getCollectionName('compare', lang) as 'compare' | 'compare-en';
const guidesCollection = getCollectionName('guides', lang) as 'guides' | 'guides-en';
const [compareArticles, guidesArticles] = await Promise.all([
  getCollection(compareCollection),
  getCollection(guidesCollection),
]);

const chinaTags = ['国内', 'china', '百炼', '火山方舟', 'coding-plan', 'trae-cn', 'api-relay', 'claude-code', 'cline'];
const chinaCompare = compareArticles
  .filter(a => !a.data.draft && (a.data.tags || []).some((tag: string) => chinaTags.includes(tag.toLowerCase())))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);

const chinaGuides = guidesArticles
  .filter(a => !a.data.draft && (a.data.tags || []).some((tag: string) => chinaTags.includes(tag.toLowerCase())))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);

const seoTitle = lang === 'zh'
  ? '国内开发者 AI 编程工具选型指南 | CodePick'
  : 'AI Coding Tools for China Developers | CodePick';
const seoDesc = lang === 'zh'
  ? '无需翻墙、国内直连、支持人民币支付的 AI 编程工具和方案推荐。'
  : 'No VPN needed, China-native access, RMB payment supported. Best AI coding tools and plans for developers in China.';
---

<BaseLayout title={seoTitle} description={seoDesc} lang={lang}>
  <article class="container py-12 max-w-4xl">
    <!-- Hero -->
    <section class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold mb-4 border bg-[var(--surface-card)] border-[var(--surface-border)]">
        <span>🇨🇳</span>
        {lang === 'zh' ? '国内开发者专题' : 'China Developer Guide'}
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-[var(--text-primary)] mb-4">
        {lang === 'zh' ? '国内开发者选型指南' : 'Guide for China Developers'}
      </h1>
      <p class="text-[var(--text-secondary)] max-w-2xl mx-auto mb-6">
        {lang === 'zh'
          ? '精选无需翻墙、国内直连、支持人民币支付的 AI 编程工具和方案。覆盖 IDE、插件、CLI 等多种场景。'
          : 'Curated AI coding tools and plans with China-native access, no VPN needed, and RMB payment support.'}
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="#tools" class="btn btn-primary">
          {lang === 'zh' ? '查看国内可用工具' : 'View China-Accessible Tools'}
        </a>
        <a href="#plans" class="btn btn-ghost">
          {lang === 'zh' ? '查看国内方案' : 'View China Plans'}
        </a>
      </div>
    </section>

    <!-- Why -->
    <section class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
      <div class="card p-5 text-center">
        <div class="text-2xl mb-2">🚀</div>
        <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1">
          {lang === 'zh' ? '国内直连' : 'Direct China Access'}
        </h3>
        <p class="text-xs text-[var(--text-muted)]">
          {lang === 'zh' ? '无需代理，低延迟，随时可用' : 'No proxy needed, low latency, always available'}
        </p>
      </div>
      <div class="card p-5 text-center">
        <div class="text-2xl mb-2">💳</div>
        <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1">
          {lang === 'zh' ? '人民币支付' : 'RMB Payment'}
        </h3>
        <p class="text-xs text-[var(--text-muted)]">
          {lang === 'zh' ? '支持支付宝、微信、国内银行卡' : 'Alipay, WeChat Pay, domestic cards'}
        </p>
      </div>
      <div class="card p-5 text-center">
        <div class="text-2xl mb-2">💰</div>
        <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1">
          {lang === 'zh' ? '成本更低' : 'Lower Cost'}
        </h3>
        <p class="text-xs text-[var(--text-muted)]">
          {lang === 'zh' ? 'Coding Plan 方案比海外订阅更省' : 'Coding Plans cheaper than overseas subs'}
        </p>
      </div>
    </section>

    <!-- Tools -->
    <section class="mb-12" id="tools">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-[var(--text-primary)] m-0">
          {lang === 'zh' ? '国内可用工具' : 'China-Accessible Tools'}
        </h2>
        <a href={localePath('/tools/china', lang)} class="text-sm text-[var(--brand-400)] no-underline hover:underline">
          {lang === 'zh' ? '查看全部 →' : 'View all →'}
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {chinaTools.slice(0, 6).map(t => <ToolCard tool={t} lang={lang} />)}
      </div>
    </section>

    <!-- Plans -->
    <section class="mb-12" id="plans">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-[var(--text-primary)] m-0">
          {lang === 'zh' ? '国内推荐方案' : 'Recommended China Plans'}
        </h2>
        <a href={localePath('/plans', lang)} class="text-sm text-[var(--brand-400)] no-underline hover:underline">
          {lang === 'zh' ? '查看全部 →' : 'View all →'}
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {chinaPlans.slice(0, 6).map(p => <PlanCard plan={p} lang={lang} />)}
      </div>
    </section>

    <!-- Guides -->
    {chinaGuides.length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-[var(--text-primary)] mb-4 mt-0">
          {lang === 'zh' ? '配置指南' : 'Setup Guides'}
        </h2>
        <div class="grid grid-cols-1 gap-3">
          {chinaGuides.map(g => (
            <a href={localePath(`/guides/${g.slug}`, lang)} class="card p-4 block no-underline group hover:border-[var(--brand-500)] transition-colors">
              <h3 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--brand-400)] m-0 mb-1">{g.data.title}</h3>
              <p class="text-xs text-[var(--text-muted)] m-0 line-clamp-1">{g.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Comparisons -->
    {chinaCompare.length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-[var(--text-primary)] mb-4 mt-0">
          {lang === 'zh' ? '相关对比' : 'Related Comparisons'}
        </h2>
        <div class="grid grid-cols-1 gap-3">
          {chinaCompare.map(a => (
            <a href={localePath(`/compare/${a.slug}`, lang)} class="card p-4 block no-underline group hover:border-[var(--brand-500)] transition-colors">
              <h3 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--brand-400)] m-0 mb-1">{a.data.title}</h3>
              <p class="text-xs text-[var(--text-muted)] m-0 line-clamp-1">{a.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
