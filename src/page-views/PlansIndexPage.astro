---
import BaseLayout from '../layouts/BaseLayout.astro';
import FilterBar from '../components/FilterBar.astro';
import PlanCard from '../components/PlanCard.astro';
import CompareTable from '../components/CompareTable.astro';
import { getAllPlansLocalized, overallScore } from '../lib/data';
import { t, localePath, type Locale } from '../lib/i18n';

interface Props { lang: Locale }
const { lang } = Astro.props;

const plans = getAllPlansLocalized(lang).sort((a, b) => overallScore(b.scores) - overallScore(a.scores));
const filterTags = ['all', 'ide', 'diy', 'cli', 'budget', 'china', 'agent'];

const seoTitle = lang === 'zh'
  ? `CodePick - 方案推荐 | 找到最适合你的 AI 编程方案`
  : `CodePick - Plan Recommendations | Find Your Perfect AI Coding Plan`;
const seoDesc = lang === 'zh'
  ? '横向对比 14 套 AI 编程方案，按综合评分、成本效率、国内可用性等多维度筛选，快速找到最优组合。'
  : 'Compare 14 AI coding plans by overall score, cost efficiency, China accessibility, and more. Find your best match.';
---
<BaseLayout title={seoTitle} description={seoDesc} lang={lang}>
  <!-- Hero -->
  <section class="relative container pt-16 pb-12 text-center">
    <div class="hero-glow" aria-hidden="true"></div>
    <h1 class="text-3xl md:text-4xl font-bold text-[var(--text-primary)] mb-4">
      {lang === 'zh' ? '找到最适合你的 AI 编程方案' : 'Find Your Perfect AI Coding Plan'}
    </h1>
    <p class="text-[var(--text-secondary)] max-w-2xl mx-auto mb-8">
      {lang === 'zh'
        ? '已评测 14 套方案，覆盖 IDE、插件、CLI 等多种组合。按你的需求筛选，找到最优组合。'
        : '14 plans evaluated, covering IDE, plugin, and CLI combinations. Filter by your needs to find your best match.'}
    </p>
    <div class="flex justify-center gap-4 flex-wrap">
      <a href="#all-plans" class="btn btn-primary px-6 py-2.5">
        {lang === 'zh' ? '浏览全部方案' : 'Browse All Plans'}
      </a>
    </div>
  </section>

  <!-- All Plans Grid -->
  <hr class="section-divider my-12" />
  <section class="container mb-16 reveal" id="all-plans">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-xl font-bold text-[var(--text-primary)] m-0">
          {t('section.planMatrix', lang)}
        </h2>
        <p class="text-xs text-[var(--text-muted)] mt-1 mb-0">
          {lang === 'zh' ? `共 ${plans.length} 个方案，按综合评分排序` : `${plans.length} plans, sorted by overall score`}
        </p>
      </div>
    </div>
    <div class="mb-6"><FilterBar tags={filterTags} activeTag="all" lang={lang} /></div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {plans.map(plan => (
        <div data-plan-tags={plan.tags.join(',')} data-plan-id={plan.id}>
          <PlanCard plan={plan} lang={lang} />
        </div>
      ))}
    </div>
  </section>

  <!-- Full Compare Table -->
  <section class="container mb-20 reveal">
    <h2 class="text-xl font-bold text-[var(--text-primary)] mb-6">
      {t('section.compareTable', lang)}
    </h2>
    <CompareTable plans={plans} lang={lang} />
  </section>
</BaseLayout>
