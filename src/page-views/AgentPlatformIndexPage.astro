---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import { getAllToolsLocalized } from '../lib/data';
import { t, localePath, type Locale } from '../lib/i18n';

interface Props { lang: Locale }
const { lang } = Astro.props;

const allTools = getAllToolsLocalized(lang);
const tools = allTools.filter(tool => tool.type === 'agent_platform')
  .sort((a, b) => (b.scores.coding_ability ?? 0) - (a.scores.coding_ability ?? 0));

const siteUrl = 'https://codepick.dev';
const pagePath = localePath('/agents', lang);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: lang === 'zh' ? 'Agent 协作平台' : 'Agent Collaboration Platforms',
  url: `${siteUrl}${pagePath}`,
  numberOfItems: tools.length,
  itemListElement: tools.map((tool, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: tool.name,
    url: `${siteUrl}${localePath(`/tool/${tool.id}`, lang)}`,
  })),
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t('bread.home', lang), item: siteUrl },
    { '@type': 'ListItem', position: 2, name: t('bread.agentPlatforms', lang), item: `${siteUrl}${pagePath}` },
  ],
};

const seoTitle = lang === 'zh'
  ? `Agent 协作平台 | Slock、Multica | CodePick`
  : `Agent Collab Platforms | Slock, Multica | CodePick`;
const seoDesc = lang === 'zh'
  ? `${tools.length} 款 Agent 协作平台：Slock、Multica。让人和 AI Agent 在同一平台协作分工，实现多 Agent 团队管理。`
  : `${tools.length} agent collaboration platforms: Slock, Multica. Where humans and AI agents collaborate as a team.`;
---

<BaseLayout title={seoTitle} description={seoDesc} jsonLd={[jsonLd, breadcrumb]} lang={lang}>
  <section class="container py-12">
    <nav class="text-xs text-[var(--text-muted)] mb-6">
      <a href={localePath('/', lang)} class="hover:text-[var(--text-primary)] no-underline">{t('bread.home', lang)}</a>
      <span class="mx-1">/</span>
      <span class="text-[var(--text-secondary)]">{t('bread.agentPlatforms', lang)}</span>
    </nav>

    <h1 class="text-3xl font-bold text-[var(--text-primary)] mb-3">{t('agents.title', lang)}</h1>
    <p class="text-[var(--text-secondary)] mb-2 max-w-2xl">
      {t('agents.subtitle', lang)}
    </p>
    <p class="text-sm text-[var(--text-muted)] mb-8 max-w-2xl">
      {t('agents.desc1', lang)}{tools.length}{t('agents.desc2', lang)}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
      {tools.map(tool => <ToolCard tool={tool} lang={lang} />)}
    </div>

    <!-- Why Agent Platforms section -->
    <div class="border-t border-[var(--surface-border)] pt-10 mt-8">
      <h2 class="text-xl font-semibold text-[var(--text-primary)] mb-3">{t('agents.whyTitle', lang)}</h2>
      <p class="text-[var(--text-secondary)] max-w-2xl leading-relaxed">
        {t('agents.whyDesc1', lang)}
      </p>
    </div>

    <div class="mt-8">
      <a href={localePath('/', lang)} class="text-sm text-[var(--text-muted)] hover:text-[var(--text-primary)] no-underline">
        {t('agents.ctaHome', lang)}
      </a>
    </div>
  </section>
</BaseLayout>
