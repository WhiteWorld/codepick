---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, localePath, getCollectionName, type Locale } from '../lib/i18n';

interface Props { lang: Locale }
const { lang } = Astro.props;

const collectionName = getCollectionName('compare', lang) as 'compare' | 'compare-en';
const articles = (await getCollection(collectionName))
  .filter(a => !a.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// 分类过滤配置：每个分类对应一组匹配 tag
const categories = [
  { key: 'all',     labelZh: '全部',     labelEn: 'All',          tags: [] as string[] },
  { key: 'ide',     labelZh: 'AI IDE',   labelEn: 'AI IDE',       tags: ['ide', 'ai-ide', 'cursor', 'windsurf', 'kiro', 'trae', 'trae-cn', 'antigravity'] },
  { key: 'plugin',  labelZh: '插件/CLI', labelEn: 'Plugin / CLI', tags: ['cline', 'roo-code', 'copilot', 'aider', 'opencode', 'claude-code', 'gemini-cli', 'codex-cli', 'cli', '终端', 'terminal'] },
  { key: 'china',   labelZh: '国内方案', labelEn: 'China Access',  tags: ['国内', 'china', '百炼', '火山方舟', 'coding-plan', 'trae-cn', 'api-relay'] },
  { key: 'vs',      labelZh: '工具对比', labelEn: 'Head-to-Head',  tags: ['对比', 'vs', 'comparison', 'alternatives', '替代品'] },
];

function matchesCategory(articleTags: string[], catTags: string[]) {
  if (catTags.length === 0) return true;
  const lowerTags = articleTags.map(t => t.toLowerCase());
  return catTags.some(ct => lowerTags.some(at => at.includes(ct.toLowerCase()) || ct.toLowerCase().includes(at)));
}

const seoTitle = lang === 'zh'
  ? 'AI 编程工具对比文章 | CodePick'
  : 'AI Coding Tool Comparisons | CodePick';
const seoDesc = lang === 'zh'
  ? '深度对比主流 AI 编程工具方案：Cursor vs Copilot、Cline vs Roo Code、终端 AI 工具横评。'
  : 'In-depth comparisons of popular AI coding tools: Cursor vs Copilot, Cline vs Roo Code, terminal AI tools.';
---

<BaseLayout title={seoTitle} description={seoDesc} lang={lang}>
  <section class="container py-12 max-w-3xl">
    <h1 class="text-3xl font-bold text-[var(--text-primary)] mb-2">{t('compare.title', lang)}</h1>
    <p class="text-[var(--text-secondary)] mb-6">{t('compare.subtitle', lang)}</p>

    <!-- Category Filter Tabs -->
    <div class="flex flex-wrap gap-2 mb-8" id="compare-filter">
      {categories.map(cat => {
        const count = cat.tags.length === 0
          ? articles.length
          : articles.filter(a => matchesCategory(a.data.tags || [], cat.tags)).length;
        const label = lang === 'zh' ? cat.labelZh : cat.labelEn;
        return (
          <button
            data-cat={cat.key}
            class={`px-3 py-1.5 rounded-full text-sm font-medium border transition-colors cursor-pointer
              ${cat.key === 'all'
                ? 'bg-[var(--brand-500)] text-white border-[var(--brand-500)]'
                : 'bg-transparent text-[var(--text-secondary)] border-[var(--surface-border)] hover:border-[var(--brand-400)] hover:text-[var(--brand-400)]'
              }`}
          >
            {label} <span class="opacity-60 text-xs">({count})</span>
          </button>
        );
      })}
    </div>

    <div class="space-y-4" id="compare-list">
      {articles.map(article => (
        <a
          href={localePath(`/compare/${article.slug}`, lang)}
          class="card p-6 block no-underline hover:border-[var(--brand-400)] transition-colors"
          data-tags={JSON.stringify((article.data.tags || []).map((t: string) => t.toLowerCase()))}
        >
          <div class="flex flex-wrap gap-2 mb-2">
            {article.data.tags?.slice(0, 4).map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          <h2 class="text-lg font-semibold text-[var(--text-primary)] mt-2 mb-1">{article.data.title}</h2>
          <p class="text-sm text-[var(--text-muted)] m-0 mb-2">{article.data.description}</p>
          <span class="text-xs text-[var(--text-muted)]">{article.data.date}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<script define:vars={{ categories: JSON.stringify(categories) }}>
  const cats = JSON.parse(categories);
  const filterEl = document.getElementById('compare-filter');
  const listEl = document.getElementById('compare-list');

  filterEl?.addEventListener('click', (e) => {
    const btn = e.target.closest('button[data-cat]');
    if (!btn) return;
    const activeCat = btn.dataset.cat;

    // Update button styles
    filterEl.querySelectorAll('button[data-cat]').forEach(b => {
      if (b.dataset.cat === activeCat) {
        b.classList.add('bg-[var(--brand-500)]', 'text-white', 'border-[var(--brand-500)]');
        b.classList.remove('bg-transparent', 'text-[var(--text-secondary)]', 'border-[var(--surface-border)]', 'hover:border-[var(--brand-400)]', 'hover:text-[var(--brand-400)]');
      } else {
        b.classList.remove('bg-[var(--brand-500)]', 'text-white', 'border-[var(--brand-500)]');
        b.classList.add('bg-transparent', 'text-[var(--text-secondary)]', 'border-[var(--surface-border)]', 'hover:border-[var(--brand-400)]', 'hover:text-[var(--brand-400)]');
      }
    });

    // Filter articles
    const catData = cats.find(c => c.key === activeCat);
    const catTags = catData?.tags || [];
    listEl?.querySelectorAll('a[data-tags]').forEach(card => {
      const articleTags = JSON.parse(card.dataset.tags || '[]');
      const visible = catTags.length === 0 || catTags.some(ct =>
        articleTags.some(at => at.includes(ct.toLowerCase()) || ct.toLowerCase().includes(at))
      );
      card.style.display = visible ? '' : 'none';
    });
  });
</script>
