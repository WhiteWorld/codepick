---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllToolsLocalized, getAllApisLocalized } from '../lib/data';
import { t, localePath, type Locale } from '../lib/i18n';

interface Props { lang: Locale }
const { lang } = Astro.props;

const allTools = getAllToolsLocalized(lang);
const allApis = getAllApisLocalized(lang);

// 工具：按有无推广链接、有无免费版排序（推广链接优先，免费版次之）
const tools = allTools.map(tool => {
  const affiliateUrl = (tool as any).affiliate_url || '';
  const registerUrl  = (tool as any).register_url || '';
  const ctaUrl       = affiliateUrl || registerUrl || (tool as any).url || '';
  const hasFree      = ((tool as any).pricing?.plans || []).some((p: any) => p.price === 0);
  const hasAffiliate = !!affiliateUrl;
  const affiliateNote = lang === 'en'
    ? (tool as any).affiliate_note_en || (tool as any).affiliate_note || ''
    : (tool as any).affiliate_note || '';

  // 最低价展示
  const plans: any[] = (tool as any).pricing?.plans || [];
  const currency = (tool as any).pricing?.currency === 'CNY' ? '¥' : '$';
  const lowestPaid = plans.filter(p => typeof p.price === 'number' && p.price > 0)
    .sort((a, b) => a.price - b.price)[0];
  const priceLabel = hasFree
    ? t('deals.free', lang)
    : lowestPaid
      ? `${currency}${lowestPaid.price}/月`
      : '—';

  return { tool, ctaUrl, hasFree, hasAffiliate, affiliateNote, priceLabel };
}).sort((a, b) => {
  if (a.hasAffiliate !== b.hasAffiliate) return a.hasAffiliate ? -1 : 1;
  if (a.hasFree !== b.hasFree) return a.hasFree ? -1 : 1;
  return 0;
});

// Coding Plan API 源：仅展示 id 含 coding-plan 的条目
const codingPlanApis = allApis
  .filter(api => (api as any).id?.includes('coding-plan'))
  .map(api => {
    const raw = api as any;
    const ctaUrl = raw.affiliate_url || raw.url || '';
    const hasAffiliate = !!raw.affiliate_url;
    const affiliateNote = lang === 'en'
      ? raw.affiliate_note_en || raw.affiliate_note || ''
      : raw.affiliate_note || '';
    const currency = raw.pricing?.currency === 'CNY' ? '¥' : '$';
    const pricingPlans: any[] = raw.pricing?.plans || [];
    const lowestPlan = pricingPlans
      .filter(p => typeof p.price === 'number' && p.price > 0)
      .sort((a: any, b: any) => a.price - b.price)[0];
    const priceLabel = lowestPlan ? `${currency}${lowestPlan.price}/月起` : '—';
    const pricingNote: string = raw.pricing?.note || '';
    const bestFor: string[] = raw.best_for || [];
    return { api: raw, ctaUrl, hasAffiliate, affiliateNote, priceLabel, pricingNote, bestFor };
  });

const hasAnyAffiliate = tools.some(t => t.hasAffiliate) || codingPlanApis.some(p => p.hasAffiliate);

const seoTitle = t('deals.seoTitle', lang);
const seoDesc  = t('deals.seoDesc', lang);
---

<BaseLayout title={seoTitle} description={seoDesc} lang={lang}>
  <div class="container py-12 max-w-5xl">

    <!-- Header -->
    <div class="mb-10 text-center">
      <h1 class="text-3xl font-bold text-[var(--text-primary)] mb-3">{t('deals.title', lang)}</h1>
      <p class="text-[var(--text-secondary)] max-w-xl mx-auto">{t('deals.subtitle', lang)}</p>
    </div>

    <!-- Tools Section -->
    <section class="mb-14">
      <h2 class="text-xl font-semibold text-[var(--text-primary)] mb-5">{t('deals.toolsTitle', lang)}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {tools.map(({ tool, ctaUrl, hasFree, hasAffiliate, affiliateNote, priceLabel }) => (
          <div class="card p-5 flex flex-col gap-3">
            <!-- Tool Header -->
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg avatar-gradient text-base shrink-0 flex items-center justify-center font-bold text-white">
                {tool.name.charAt(0)}
              </div>
              <div class="min-w-0">
                <a href={localePath(`/tool/${tool.id}`, lang)} class="text-sm font-semibold text-[var(--text-primary)] no-underline hover:text-[var(--brand-400)]">
                  {tool.name}
                </a>
                <p class="text-xs text-[var(--text-muted)] m-0 truncate">{(tool as any).tagline || (tool as any).type}</p>
              </div>
            </div>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5">
              {hasFree && (
                <span class="text-xs bg-emerald-900/50 text-emerald-400 border border-emerald-700 px-2 py-0.5 rounded-full">
                  {t('deals.freeTag', lang)}
                </span>
              )}
              {hasAffiliate && (
                <span class="text-xs bg-amber-900/50 text-amber-400 border border-amber-700 px-2 py-0.5 rounded-full">
                  {t('deals.affiliateTag', lang)}
                </span>
              )}
              <span class="text-xs bg-[var(--surface-2)] text-[var(--text-muted)] px-2 py-0.5 rounded-full">
                {priceLabel}
              </span>
            </div>

            <!-- Affiliate note -->
            {affiliateNote && (
              <p class="text-xs text-amber-400 m-0">{affiliateNote}</p>
            )}

            <!-- CTA -->
            {ctaUrl && (
              <a href={ctaUrl} target="_blank" rel="noopener noreferrer"
                 class={`mt-auto inline-flex items-center justify-center gap-1 text-sm font-semibold px-4 py-2 rounded-lg no-underline transition-colors ${hasFree ? 'bg-emerald-600 hover:bg-emerald-500 text-white' : 'bg-[var(--brand-500)] hover:bg-[var(--brand-400)] text-white'}`}>
                {hasFree ? t('cta.freeTrial', lang) : t('cta.tryNow', lang)} ↗
              </a>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Coding Plan APIs Section -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-[var(--text-primary)] mb-5">{t('deals.plansTitle', lang)}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {codingPlanApis.map(({ api, ctaUrl, hasAffiliate, affiliateNote, priceLabel, pricingNote, bestFor }) => (
          <div class="card p-5 flex flex-col gap-3">
            <!-- API Header -->
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg avatar-gradient text-base shrink-0 flex items-center justify-center font-bold text-white">
                {api.name.charAt(0)}
              </div>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-[var(--text-primary)] m-0">{api.name}</p>
                {bestFor[0] && (
                  <p class="text-xs text-[var(--text-muted)] m-0 truncate">{bestFor[0]}</p>
                )}
              </div>
            </div>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5">
              {hasAffiliate && (
                <span class="text-xs bg-amber-900/50 text-amber-400 border border-amber-700 px-2 py-0.5 rounded-full">
                  {t('deals.affiliateTag', lang)}
                </span>
              )}
              <span class="text-xs bg-[var(--surface-2)] text-[var(--text-muted)] px-2 py-0.5 rounded-full font-medium">
                {priceLabel}
              </span>
            </div>

            <!-- Pricing note -->
            {pricingNote && (
              <p class="text-xs text-amber-400 m-0">{pricingNote}</p>
            )}

            <!-- Affiliate note -->
            {affiliateNote && (
              <p class="text-xs text-amber-400 m-0">{affiliateNote}</p>
            )}

            <!-- CTA -->
            {ctaUrl && (
              <a href={ctaUrl} target="_blank" rel="noopener noreferrer"
                 class="mt-auto inline-flex items-center justify-center gap-1 text-sm font-semibold bg-[var(--brand-500)] hover:bg-[var(--brand-400)] text-white px-4 py-2 rounded-lg no-underline transition-colors">
                {t('cta.tryNow', lang)} ↗
              </a>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Affiliate disclosure -->
    {hasAnyAffiliate && (
      <p class="text-xs text-[var(--text-muted)] text-center border-t border-[var(--surface-border)] pt-6">
        {t('deals.note', lang)}
      </p>
    )}

  </div>
</BaseLayout>
