---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import { getCollection } from 'astro:content';
import { t, localePath, getAlternateLangUrl, type Locale } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  jsonLd?: object | object[];
  lang?: Locale;
}

const {
  lang = 'zh',
  title = t('seo.defaultTitle', lang),
  description = t('seo.defaultDesc', lang),
  image = '/og-image.png',
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  jsonLd,
} = Astro.props;

const siteUrl = 'https://codepick.dev';
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
const htmlLang = lang === 'zh' ? 'zh-CN' : 'en';
const ogLocale = lang === 'zh' ? 'zh_CN' : 'en_US';
const altLangUrl = new URL(getAlternateLangUrl(Astro.url, lang), Astro.site).href;
const zhUrl = lang === 'zh' ? canonicalURL : altLangUrl;
const enUrl = lang === 'en' ? canonicalURL : altLangUrl;

// Default site-level JSON-LD
const defaultJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'CodePick',
    url: siteUrl,
    description: t('seo.siteDesc', lang),
    inLanguage: htmlLang,
    potentialAction: {
      '@type': 'SearchAction',
      target: `${siteUrl}/${lang}/tools?q={search_term_string}`,
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'CodePick',
    url: siteUrl,
    logo: `${siteUrl}/favicon.svg`,
    sameAs: ['https://github.com/WhiteWorld/codepick'],
  },
];

const allJsonLd = jsonLd
  ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd])
  : defaultJsonLd;

const navLinks = [
  { href: localePath('/coding-plan', lang), label: t('nav.codingPlan', lang) },
  { href: localePath('/', lang), label: t('nav.plans', lang) },
  { href: localePath('/tools', lang), label: t('nav.tools', lang) },
  { href: localePath('/tools/overview', lang), label: t('nav.overview', lang) },
  { href: localePath('/tools/compare', lang), label: t('nav.comparator', lang) },
  { href: localePath('/compare', lang), label: t('nav.compare', lang) },
  { href: localePath('/guides', lang), label: t('nav.guides', lang) },
  { href: localePath('/prompts', lang), label: t('nav.prompts', lang) },
  { href: localePath('/deals', lang), label: t('nav.deals', lang) },
  { href: localePath('/faq', lang), label: t('nav.faq', lang) },
];

const otherLang = lang === 'zh' ? 'en' : 'zh';
const switchLabel = lang === 'zh' ? 'EN' : '中文';
const switchUrl = getAlternateLangUrl(Astro.url, lang);

// Compute the most recent content date across all collections for the footer
const allCollections = await Promise.all([
  getCollection('compare'),
  getCollection('compare-en'),
  getCollection('guides'),
  getCollection('guides-en'),
]);
const latestDate = allCollections
  .flat()
  .filter(entry => !entry.data.draft)
  .map(entry => entry.data.date)
  .filter(Boolean)
  .sort()
  .at(-1);
const latestUpdateMonth = latestDate
  ? latestDate.slice(0, 7)   // YYYY-MM
  : '2026-04';
---

<!DOCTYPE html>
<html lang={htmlLang} data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL} />

  <!-- hreflang alternates -->
  <link rel="alternate" hreflang="zh" href={zhUrl} />
  <link rel="alternate" hreflang="en" href={enUrl} />
  <link rel="alternate" hreflang="x-default" href={zhUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="CodePick" />
  <meta property="og:locale" content={ogLocale} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.loli.net" />
  <link rel="preconnect" href="https://gstatic.loli.net" crossorigin />
  <link href="https://fonts.loli.net/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- JSON-LD Structured Data -->
  {allJsonLd.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <Analytics />

  <!-- Prevent FOUC: apply saved theme before paint -->
  <script is:inline>
    (function() {
      var saved = localStorage.getItem('theme');
      var theme = saved || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<body>
  <!-- Navigation -->
  <nav class="sticky top-0 z-50 border-b border-[var(--surface-border)] bg-[var(--surface-nav)] backdrop-blur-xl">
    <div class="container flex items-center justify-between h-16">
      <a href={localePath('/', lang)} class="flex items-center gap-2 text-lg font-bold text-[var(--text-primary)] no-underline">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-[var(--brand-400)]" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        <span>CodePick</span>
      </a>
      <div class="hidden md:flex items-center gap-6">
        {navLinks.map(link => {
          const isActive = Astro.url.pathname === link.href || (link.href !== localePath('/', lang) && Astro.url.pathname.startsWith(link.href + '/') && !navLinks.some(other => other.href !== link.href && other.href !== localePath('/', lang) && Astro.url.pathname.startsWith(other.href + '/')));
          return (
            <a
              href={link.href}
              class={`text-sm transition-colors no-underline pb-0.5 ${isActive
                ? 'text-[var(--text-primary)] border-b-2 border-[var(--brand-400)]'
                : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)] border-b-2 border-transparent'
              }`}
            >
              {link.label}
            </a>
          );
        })}
      </div>
      <div class="flex items-center gap-3">
        <button id="theme-toggle" class="btn btn-ghost p-2 text-sm" aria-label={lang === 'zh' ? '切换主题' : 'Toggle theme'}>
          <svg class="theme-icon-light hidden w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
          <svg class="theme-icon-dark w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <a href={switchUrl} class="btn btn-ghost text-xs">{switchLabel}</a>
        <a
          href="https://github.com/WhiteWorld/codepick"
          target="_blank"
          rel="noopener"
          class="btn btn-ghost text-xs"
        >
          GitHub ↗
        </a>
        <button id="menu-toggle" class="md:hidden btn btn-ghost p-2" aria-label={t('menu.ariaLabel', lang)}>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 010 2H4a1 1 0 01-1-1zm0 5a1 1 0 011-1h12a1 1 0 010 2H4a1 1 0 01-1-1zm0 5a1 1 0 011-1h12a1 1 0 010 2H4a1 1 0 01-1-1z" clip-rule="evenodd"/>
          </svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="overflow-hidden transition-all duration-200 md:hidden border-t border-[var(--surface-border)] bg-[var(--surface-bg)]" style="max-height: 0;">
      <div class="container py-3 flex flex-col gap-2">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] py-2 no-underline"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="border-t border-[var(--surface-border)] mt-20">
    <div class="container py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <h3 class="text-[var(--text-primary)] font-semibold mb-3 flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-[var(--brand-400)]" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>CodePick</h3>
          <p class="text-sm text-[var(--text-muted)] leading-relaxed">
            {t('footer.desc', lang)}<br/>
            {t('footer.descLine2', lang)}
          </p>
        </div>
        <div>
          <h4 class="text-[var(--text-secondary)] font-semibold mb-3 text-sm">{t('footer.quickNav', lang)}</h4>
          <div class="flex flex-col gap-2">
            {navLinks.map(link => (
              <a href={link.href} class="text-sm text-[var(--text-muted)] hover:text-[var(--text-primary)] no-underline">{link.label}</a>
            ))}
          </div>
        </div>
        <div>
          <h4 class="text-[var(--text-secondary)] font-semibold mb-3 text-sm">{t('footer.about', lang)}</h4>
          <div class="flex flex-col gap-2 text-sm text-[var(--text-muted)]">
            <span>{t('footer.personal', lang)}</span>
            <span>{t('footer.lastUpdate', lang)} {latestUpdateMonth}</span>
            <a href="https://github.com/WhiteWorld/codepick/issues" target="_blank" rel="noopener" class="hover:text-[var(--text-primary)] no-underline">{t('footer.reportLink', lang)}</a>
          </div>
        </div>
      </div>
      <div class="mt-8 pt-6 border-t border-[var(--surface-border)] text-center text-xs text-[var(--text-muted)]">
        {t('footer.copyright', lang)}
      </div>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu') as HTMLElement | null;
    let menuOpen = false;
    toggle?.addEventListener('click', () => {
      menuOpen = !menuOpen;
      if (menu) {
        menu.style.maxHeight = menuOpen ? '400px' : '0';
      }
    });

    // Scroll reveal
    if ('IntersectionObserver' in window) {
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
    } else {
      document.querySelectorAll('.reveal').forEach(el => el.classList.add('revealed'));
    }

    // Theme toggle
    function updateThemeIcons(theme: string) {
      const lightIcon = document.querySelector('.theme-icon-light') as HTMLElement | null;
      const darkIcon = document.querySelector('.theme-icon-dark') as HTMLElement | null;
      if (theme === 'light') {
        lightIcon?.classList.remove('hidden');
        darkIcon?.classList.add('hidden');
      } else {
        lightIcon?.classList.add('hidden');
        darkIcon?.classList.remove('hidden');
      }
    }

    const themeBtn = document.getElementById('theme-toggle');
    const currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
    updateThemeIcons(currentTheme);

    themeBtn?.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme') || 'dark';
      const next = current === 'light' ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      updateThemeIcons(next);
    });
  </script>
</body>
</html>
