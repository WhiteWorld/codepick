---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { getAllTools } from '../../lib/data';

const allTools = getAllTools();

// 终端工具：type === 'cli' 或 ide_base 包含 '终端'
const tools = allTools.filter(tool => {
  const ideBase = ((tool as any).features?.ide_base || '').toLowerCase();
  return tool.type === 'cli' || ideBase.includes('终端') || ideBase.includes('tui') || ideBase.includes('cli');
}).sort((a, b) => (b.scores.coding_ability ?? 0) - (a.scores.coding_ability ?? 0));

const siteUrl = 'https://codepick.dev';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '终端 AI 编程工具',
  description: '在终端/命令行运行的 AI 编程工具，适合 Vim/Neovim 用户和偏好终端工作流的开发者',
  url: `${siteUrl}/tools/terminal`,
  numberOfItems: tools.length,
  itemListElement: tools.map((tool, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: tool.name,
    url: `${siteUrl}/tool/${tool.id}`,
  })),
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: '工具库', item: `${siteUrl}/tools` },
    { '@type': 'ListItem', position: 3, name: '终端工具', item: `${siteUrl}/tools/terminal` },
  ],
};
---

<BaseLayout
  title="终端 AI 编程工具 | CLI | CodePick"
  description={`${tools.length} 款终端/CLI AI 编程工具：Claude Code、OpenCode、Aider。适合 Vim 用户、终端党，支持任意编辑器工作流。`}
  jsonLd={[jsonLd, breadcrumb]}
>
  <section class="container py-12">
    <!-- Breadcrumb -->
    <nav class="text-xs text-[var(--text-muted)] mb-6">
      <a href="/" class="hover:text-[var(--text-primary)] no-underline">首页</a>
      <span class="mx-1">/</span>
      <a href="/tools" class="hover:text-[var(--text-primary)] no-underline">工具库</a>
      <span class="mx-1">/</span>
      <span class="text-[var(--text-secondary)]">终端工具</span>
    </nav>

    <h1 class="text-3xl font-bold text-[var(--text-primary)] mb-3">⌨️ 终端 AI 编程工具</h1>
    <p class="text-[var(--text-secondary)] mb-4 max-w-2xl">
      在终端中运行的 AI 编程 CLI 工具，不依赖特定 IDE，适合 Vim/Neovim 用户、服务器开发和偏好终端工作流的开发者。
      共 {tools.length} 款，按编程能力排序。
    </p>

    <!-- Terminal tools explanation -->
    <div class="card p-4 mb-8 border-l-4 border-[var(--brand-400)]">
      <p class="text-sm text-[var(--text-secondary)] m-0">
        💡 <strong class="text-[var(--text-primary)]">终端工具的优势</strong>：不绑定特定 IDE，可在任意环境（SSH 远程、服务器、Vim）中使用；
        多数支持自定义模型 API，灵活性最高；Aider 的 Git 集成是所有工具中最完善的。
      </p>
    </div>

    <!-- Category nav -->
    <div class="flex flex-wrap gap-2 mb-8">
      <a href="/tools" class="btn btn-ghost text-sm no-underline">全部</a>
      <a href="/tools/free" class="btn btn-ghost text-sm no-underline">💰 免费工具</a>
      <a href="/tools/china" class="btn btn-ghost text-sm no-underline">🇨🇳 国内可用</a>
      <a href="/tools/vscode" class="btn btn-ghost text-sm no-underline">🔵 VS Code 生态</a>
      <span class="btn btn-primary text-sm cursor-default">⌨️ 终端工具</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {tools.map(tool => <ToolCard tool={tool} />)}
    </div>

    <!-- Related content -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-4">
      <a href="/compare/terminal-ai-tools" class="card p-5 no-underline group block">
        <h3 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--brand-400)] m-0 mb-1">终端 AI 三杰对比</h3>
        <p class="text-xs text-[var(--text-muted)] m-0">对比：Claude Code vs OpenCode vs Aider →</p>
      </a>
      <a href="/guides/ollama-aider-local" class="card p-5 no-underline group block">
        <h3 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--brand-400)] m-0 mb-1">Ollama + Aider 本地部署</h3>
        <p class="text-xs text-[var(--text-muted)] m-0">指南：终端 + 本地模型零成本方案 →</p>
      </a>
    </div>
  </section>
</BaseLayout>
