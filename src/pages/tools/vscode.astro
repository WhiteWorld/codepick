---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { getAllTools } from '../../lib/data';

const allTools = getAllTools();

// VS Code 生态：ide_base 包含 "VS Code" 或类型为 ide/client/plugin
const tools = allTools.filter(tool => {
  const ideBase = ((tool as any).features?.ide_base || '').toLowerCase();
  return ideBase.includes('vs code') || ideBase.includes('vscode');
}).sort((a, b) => (b.scores.coding_ability ?? 0) - (a.scores.coding_ability ?? 0));

const siteUrl = 'https://codepick.dev';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'VS Code AI 编程工具',
  description: '基于 VS Code 生态的 AI 编程工具，包括 VS Code Fork IDE 和 VS Code 插件',
  url: `${siteUrl}/tools/vscode`,
  numberOfItems: tools.length,
  itemListElement: tools.map((tool, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: tool.name,
    url: `${siteUrl}/tool/${tool.id}`,
  })),
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: '工具库', item: `${siteUrl}/tools` },
    { '@type': 'ListItem', position: 3, name: 'VS Code 生态', item: `${siteUrl}/tools/vscode` },
  ],
};
---

<BaseLayout
  title="VS Code AI 编程工具 | CodePick"
  description={`${tools.length} 款基于 VS Code 生态的 AI 编程工具：Cursor、Cline、Roo Code、Copilot、Trae，覆盖 VS Code Fork IDE 和 VS Code 插件。`}
  jsonLd={[jsonLd, breadcrumb]}
>
  <section class="container py-12">
    <!-- Breadcrumb -->
    <nav class="text-xs text-[var(--text-muted)] mb-6">
      <a href="/" class="hover:text-[var(--text-primary)] no-underline">首页</a>
      <span class="mx-1">/</span>
      <a href="/tools" class="hover:text-[var(--text-primary)] no-underline">工具库</a>
      <span class="mx-1">/</span>
      <span class="text-[var(--text-secondary)]">VS Code 生态</span>
    </nav>

    <h1 class="text-3xl font-bold text-[var(--text-primary)] mb-3">🔵 VS Code 生态 AI 编程工具</h1>
    <p class="text-[var(--text-secondary)] mb-4 max-w-2xl">
      基于 VS Code 的 AI 编程工具，包括 VS Code Fork IDE（Cursor、Trae）和 VS Code 插件（Cline、Roo Code、Copilot）。
      共 {tools.length} 款，按编程能力排序。
    </p>

    <!-- VS Code ecosystem explanation -->
    <div class="card p-4 mb-8 grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <p class="text-xs font-semibold text-[var(--text-secondary)] mb-1">🖥️ VS Code Fork IDE</p>
        <p class="text-xs text-[var(--text-muted)] m-0">深度定制 VS Code，内置 AI 能力，开箱即用体验最佳。代表：Cursor、Trae。</p>
      </div>
      <div>
        <p class="text-xs font-semibold text-[var(--text-secondary)] mb-1">🧩 VS Code 插件</p>
        <p class="text-xs text-[var(--text-muted)] m-0">安装在 VS Code / Cursor 中，灵活自定义模型和 API。代表：Cline、Roo Code、Copilot。</p>
      </div>
    </div>

    <!-- Category nav -->
    <div class="flex flex-wrap gap-2 mb-8">
      <a href="/tools" class="btn btn-ghost text-sm no-underline">全部</a>
      <a href="/tools/free" class="btn btn-ghost text-sm no-underline">💰 免费工具</a>
      <a href="/tools/china" class="btn btn-ghost text-sm no-underline">🇨🇳 国内可用</a>
      <span class="btn btn-primary text-sm cursor-default">🔵 VS Code 生态</span>
      <a href="/tools/terminal" class="btn btn-ghost text-sm no-underline">⌨️ 终端工具</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {tools.map(tool => <ToolCard tool={tool} />)}
    </div>

    <!-- Related content -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-4">
      <a href="/compare/cursor-vs-copilot" class="card p-5 no-underline group block">
        <h3 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--brand-400)] m-0 mb-1">Cursor vs GitHub Copilot</h3>
        <p class="text-xs text-[var(--text-muted)] m-0">对比：两大 VS Code 付费方案终极对比 →</p>
      </a>
      <a href="/compare/cline-vs-roo-code" class="card p-5 no-underline group block">
        <h3 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--brand-400)] m-0 mb-1">Cline vs Roo Code</h3>
        <p class="text-xs text-[var(--text-muted)] m-0">对比：VS Code 开源 Agent 谁更强 →</p>
      </a>
    </div>
  </section>
</BaseLayout>
