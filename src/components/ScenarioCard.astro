---
import { t, localePath, type Locale } from '../lib/i18n';

interface Props {
  lang?: Locale;
}

const { lang = 'zh' } = Astro.props;

interface Scenario {
  emoji: string;
  titleKey: string;
  descKey: string;
  href: string;
}

const scenarios: Scenario[] = [
  { emoji: '⚡', titleKey: 'sc.cursorHub.title', descKey: 'sc.cursorHub.desc', href: '/tool/cursor' },
  { emoji: '🇨🇳', titleKey: 'sc.chinaHub.title', descKey: 'sc.chinaHub.desc', href: '/tools/china' },
  { emoji: '🏆', titleKey: 'sc.cursorCopilot.title', descKey: 'sc.cursorCopilot.desc', href: '/compare/cursor-vs-copilot' },
  { emoji: '⚔️', titleKey: 'sc.clineRoo.title', descKey: 'sc.clineRoo.desc', href: '/compare/cline-vs-roo-code' },
  { emoji: '⌨️', titleKey: 'sc.terminalAi.title', descKey: 'sc.terminalAi.desc', href: '/compare/terminal-ai-tools' },
  { emoji: '🆚', titleKey: 'sc.cursorWindsurf.title', descKey: 'sc.cursorWindsurf.desc', href: '/compare/cursor-vs-windsurf' },
  { emoji: '🖥️', titleKey: 'sc.kiroCursor.title', descKey: 'sc.kiroCursor.desc', href: '/compare/kiro-vs-cursor' },
  { emoji: '🆓', titleKey: 'sc.freeTerminal.title', descKey: 'sc.freeTerminal.desc', href: '/compare/gemini-cli-vs-claude-code-vs-codex-cli' },
  { emoji: '🔥', titleKey: 'sc.clineArk.title', descKey: 'sc.clineArk.desc', href: '/guides/cline-ark-setup' },
  { emoji: '🔒', titleKey: 'sc.localDeploy.title', descKey: 'sc.localDeploy.desc', href: '/guides/ollama-aider-local' },
  { emoji: '💰', titleKey: 'sc.freeCoding.title', descKey: 'sc.freeCoding.desc', href: '/tools/free' },
];
---

<section>
  <h2 class="text-xl font-bold text-[var(--text-primary)] mb-6 mt-0">{t('section.scenarios', lang)}</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
    {scenarios.map(s => (
      <a href={localePath(s.href, lang)} class="card p-4 no-underline group block flex gap-3 items-start">
        <div class="text-2xl shrink-0 mt-0.5">{s.emoji}</div>
        <div>
          <h3 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--brand-400)] transition-colors m-0 mb-1">
            {t(s.titleKey, lang)}
          </h3>
          <p class="text-xs text-[var(--text-muted)] m-0 leading-relaxed">{t(s.descKey, lang)}</p>
        </div>
      </a>
    ))}
  </div>
</section>
